# Parallel execution demo
# Both branches run (order not guaranteed)

data = "input_data"

()parallel(`process_a`, `process_b`)
process_a:
    (data, " + processed_A")concat(result_a)
    (result_a)print()
process_b:
    (data, " + processed_B")concat(result_b)
    (result_b)print()

# After parallel completes, both results are available
("Both branches done")print()
