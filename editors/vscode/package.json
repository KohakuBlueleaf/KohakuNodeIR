{
    "name": "kohaku-node-ir",
    "displayName": "Kohaku Node IR",
    "description": "Syntax highlighting for KohakuNodeIR (.kir) files",
    "version": "0.1.0",
    "publisher": "KohakuBlueLeaf",
    "engines": {
        "vscode": "^1.75.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "kir",
                "aliases": [
                    "Kohaku Node IR",
                    "kir"
                ],
                "extensions": [
                    ".kir"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "kir",
                "scopeName": "source.kir",
                "path": "./syntaxes/kir.tmLanguage.json"
            }
        ]
    }
}
