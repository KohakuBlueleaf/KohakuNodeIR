{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Kohaku Node IR",
    "scopeName": "source.kir",
    "patterns": [
        { "include": "#section-comment" },
        { "include": "#comment" },
        { "include": "#subgraph-def" },
        { "include": "#directive" },
        { "include": "#namespace-label" },
        { "include": "#input-args" },
        { "include": "#builtin-call" },
        { "include": "#function-call" },
        { "include": "#assignment" },
        { "include": "#expression" }
    ],
    "repository": {
        "expression": {
            "patterns": [
                { "include": "#strings" },
                { "include": "#numbers" },
                { "include": "#constants" },
                { "include": "#label-ref" },
                { "include": "#switch-arrow" },
                { "include": "#keyword-arg" },
                { "include": "#wildcard" }
            ]
        },

        "section-comment": {
            "match": "^\\s*##.*$",
            "name": "comment.block.documentation.kir"
        },
        "comment": {
            "match": "#.*$",
            "name": "comment.line.hash.kir"
        },

        "directive": {
            "patterns": [
                {
                    "match": "(@mode)\\s+(\\w+)",
                    "captures": {
                        "1": { "name": "keyword.control.directive.kir" },
                        "2": { "name": "constant.language.mode.kir" }
                    }
                },
                {
                    "match": "(@dataflow)\\s*:",
                    "name": "keyword.control.directive.kir"
                },
                {
                    "comment": "@typehint block: entries inside are type declarations, not calls",
                    "begin": "(@typehint)\\s*:",
                    "beginCaptures": {
                        "1": { "name": "keyword.control.directive.kir" }
                    },
                    "end": "(?=^\\S)",
                    "patterns": [
                        { "include": "#typehint-entry" },
                        { "include": "#comment" }
                    ]
                },
                {
                    "match": "(@try)\\s*:",
                    "name": "keyword.control.directive.kir"
                },
                {
                    "match": "(@except)\\s*:",
                    "name": "keyword.control.directive.kir"
                },
                {
                    "match": "(@meta)\\b",
                    "name": "keyword.control.directive.kir"
                },
                {
                    "match": "(@def)\\b",
                    "name": "keyword.control.directive.kir"
                }
            ]
        },

        "subgraph-def": {
            "match": "(@def)\\s*\\(([^)]*)\\)(\\w+)\\(([^)]*)\\)\\s*:",
            "captures": {
                "1": { "name": "keyword.control.directive.kir" },
                "2": { "name": "variable.parameter.kir" },
                "3": { "name": "entity.name.function.definition.kir" },
                "4": { "name": "variable.other.output.kir" }
            }
        },

        "namespace-label": {
            "match": "^(\\s*)(\\w+)(\\s*:\\s*)$",
            "captures": {
                "2": { "name": "entity.name.tag.namespace.kir" },
                "3": { "name": "punctuation.separator.colon.kir" }
            }
        },

        "input-args": {
            "comment": "Input argument list: (x, y, 42, \"hello\") before )func_name(",
            "begin": "(\\()(?=[^)]*\\)[a-zA-Z_])",
            "beginCaptures": {
                "1": { "name": "punctuation.paren.open.kir" }
            },
            "end": "(?=\\))",
            "patterns": [
                { "include": "#expression" },
                {
                    "match": "\\b([a-zA-Z_]\\w*)\\b",
                    "name": "variable.other.kir"
                }
            ]
        },

        "typehint-entry": {
            "comment": "Inside @typehint block: (type, type)func_name(type)",
            "match": "^(\\s*)(\\()([^)]*)(\\))([a-zA-Z_]\\w*)(\\()([^)]*)(\\))\\s*$",
            "captures": {
                "2": { "name": "punctuation.paren.open.kir" },
                "3": { "name": "entity.name.type.kir" },
                "4": { "name": "punctuation.paren.close.kir" },
                "5": { "name": "entity.name.function.kir" },
                "6": { "name": "punctuation.paren.open.kir" },
                "7": { "name": "entity.name.type.kir" },
                "8": { "name": "punctuation.paren.close.kir" }
            }
        },

        "builtin-call": {
            "comment": "Multi-line aware: )builtin( ... ) with begin/end for the output parens",
            "begin": "(\\))(branch|switch|jump|parallel)(\\()",
            "beginCaptures": {
                "1": { "name": "punctuation.paren.close.kir" },
                "2": { "name": "keyword.control.builtin.kir" },
                "3": { "name": "punctuation.paren.open.kir" }
            },
            "end": "(\\))",
            "endCaptures": {
                "1": { "name": "punctuation.paren.close.kir" }
            },
            "patterns": [
                { "include": "#expression" },
                { "include": "#comment" }
            ]
        },

        "function-call": {
            "comment": "Multi-line aware: )func_name( ... ) with begin/end for the output parens",
            "begin": "(\\))([a-zA-Z_][a-zA-Z0-9_.]*)(\\()",
            "beginCaptures": {
                "1": { "name": "punctuation.paren.close.kir" },
                "2": { "name": "entity.name.function.kir" },
                "3": { "name": "punctuation.paren.open.kir" }
            },
            "end": "(\\))",
            "endCaptures": {
                "1": { "name": "punctuation.paren.close.kir" }
            },
            "patterns": [
                { "include": "#expression" },
                { "include": "#comment" }
            ]
        },

        "assignment": {
            "patterns": [
                {
                    "comment": "Typed assignment: name: type = expr",
                    "match": "^(\\s*)(\\w+)(\\s*:\\s*)(\\w+(?:\\s*\\?|(?:\\s*\\|\\s*\\w+)*))(\\s*=)(?!=\\>)",
                    "captures": {
                        "2": { "name": "variable.other.assignment.kir" },
                        "3": { "name": "punctuation.separator.colon.kir" },
                        "4": { "name": "entity.name.type.kir" },
                        "5": { "name": "keyword.operator.assignment.kir" }
                    }
                },
                {
                    "comment": "Plain assignment: name = expr",
                    "match": "^(\\s*)(\\w+)(\\s*=)(?!=\\>)",
                    "captures": {
                        "2": { "name": "variable.other.assignment.kir" },
                        "3": { "name": "keyword.operator.assignment.kir" }
                    }
                }
            ]
        },

        "switch-arrow": {
            "match": "=>",
            "name": "keyword.operator.arrow.kir"
        },

        "keyword-arg": {
            "match": "(\\w+)(=)(?!=\\>)(?=[^,)]*[,)])",
            "captures": {
                "1": { "name": "variable.parameter.kir" },
                "2": { "name": "keyword.operator.assignment.kir" }
            }
        },

        "label-ref": {
            "match": "`(\\w+)`",
            "name": "string.quoted.backtick.label-ref.kir",
            "captures": {
                "1": { "name": "entity.name.tag.namespace.reference.kir" }
            }
        },

        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.triple.double.kir",
                    "begin": "\"\"\"",
                    "end": "\"\"\"",
                    "patterns": [{ "include": "#string-escape" }]
                },
                {
                    "name": "string.quoted.triple.single.kir",
                    "begin": "'''",
                    "end": "'''",
                    "patterns": [{ "include": "#string-escape" }]
                },
                {
                    "name": "string.quoted.double.kir",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [{ "include": "#string-escape" }]
                },
                {
                    "name": "string.quoted.single.kir",
                    "begin": "'",
                    "end": "'",
                    "patterns": [{ "include": "#string-escape" }]
                }
            ]
        },
        "string-escape": {
            "match": "\\\\.",
            "name": "constant.character.escape.kir"
        },

        "numbers": {
            "patterns": [
                {
                    "match": "\\b0[xX][0-9a-fA-F]+\\b",
                    "name": "constant.numeric.hex.kir"
                },
                {
                    "match": "\\b0[oO][0-7]+\\b",
                    "name": "constant.numeric.oct.kir"
                },
                {
                    "match": "\\b0[bB][01]+\\b",
                    "name": "constant.numeric.bin.kir"
                },
                {
                    "match": "\\b[0-9]+\\.[0-9]*([eE][+-]?[0-9]+)?\\b",
                    "name": "constant.numeric.float.kir"
                },
                {
                    "match": "\\b\\.[0-9]+([eE][+-]?[0-9]+)?\\b",
                    "name": "constant.numeric.float.kir"
                },
                {
                    "match": "\\b[0-9]+[eE][+-]?[0-9]+\\b",
                    "name": "constant.numeric.float.kir"
                },
                {
                    "match": "\\b[0-9]+\\b",
                    "name": "constant.numeric.integer.kir"
                }
            ]
        },

        "constants": {
            "patterns": [
                {
                    "match": "\\b(True|False)\\b",
                    "name": "constant.language.boolean.kir"
                },
                {
                    "match": "\\bNone\\b",
                    "name": "constant.language.none.kir"
                }
            ]
        },

        "wildcard": {
            "match": "\\b_\\b",
            "name": "variable.language.wildcard.kir"
        }
    }
}
